<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_small"
    app:cardCornerRadius="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_medium">

        <TextView
            android:id="@+id/textBuyerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sample_buyer"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/textOfferAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/sample_item_price" />

        <TextView
            android:id="@+id/textOfferType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sample_offer_type" />

        <TextView
            android:id="@+id/textOfferStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sample_status" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAcceptOffer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/space_small"
            android:text="@string/action_accept_offer" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
