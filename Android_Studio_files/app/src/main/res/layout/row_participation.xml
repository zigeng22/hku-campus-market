<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.HkuMarket.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_compact"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_medium">

        <TextView
            android:id="@+id/textParticipationItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:text="@string/sample_activity_item"
            android:textAppearance="@style/TextAppearance.HkuMarket.ItemTitle" />

        <TextView
            android:id="@+id/textParticipationAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_small"
            android:text="@string/sample_item_price"
            android:textAppearance="@style/TextAppearance.HkuMarket.ItemPrice"
            tools:text="Your offer: HK$120.00" />

        <TextView
            android:id="@+id/textParticipationStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_extra_small"
            android:text="@string/sample_status"
            android:textAppearance="@style/TextAppearance.HkuMarket.Brand" />

        <TextView
            android:id="@+id/textCounterpartyWhatsapp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_small"
            android:background="@drawable/bg_status_notice"
            android:padding="@dimen/space_compact"
            android:text="@string/sample_whatsapp"
            android:textAppearance="@style/TextAppearance.HkuMarket.Metadata" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
