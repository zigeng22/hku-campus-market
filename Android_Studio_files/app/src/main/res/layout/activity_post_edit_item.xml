<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true"
    tools:context=".ui.item.PostEditItemActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarPostEdit"
        android:layout_width="0dp"
        android:layout_height="@dimen/home_toolbar_height"
        android:title="@string/post_item_title"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:titleTextAppearance="@style/TextAppearance.HkuMarket.ToolbarTitle" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollPostEdit"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toTopOf="@id/footerPostEdit"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarPostEdit">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/page_padding"
            android:paddingTop="@dimen/space_large"
            android:paddingEnd="@dimen/page_padding"
            android:paddingBottom="@dimen/space_extra_large">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/listing_photo_label"
                android:textAppearance="@style/TextAppearance.HkuMarket.Eyebrow" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imagePreview"
                android:layout_width="match_parent"
                android:layout_height="@dimen/item_form_image_height"
                android:layout_marginTop="@dimen/space_small"
                android:background="@drawable/bg_item_image"
                android:contentDescription="@string/item_image_description"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_item_placeholder"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.HkuMarket.ItemImage" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonChooseImage"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_small"
                android:text="@string/choose_image"
                app:icon="@drawable/ic_image_24" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_large"
                android:text="@string/listing_details_label"
                android:textAppearance="@style/TextAppearance.HkuMarket.Eyebrow" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_extra_small"
                android:layout_marginBottom="@dimen/space_medium"
                android:text="@string/listing_details_helper"
                android:textAppearance="@style/TextAppearance.HkuMarket.Metadata" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutItemName"
                style="@style/Widget.HkuMarket.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/item_name_hint"
                app:counterEnabled="true"
                app:counterMaxLength="60">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputItemName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="textCapSentences"
                    android:maxLength="60"
                    android:maxLines="2" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutDescription"
                style="@style/Widget.HkuMarket.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_compact"
                android:hint="@string/item_description_hint"
                app:counterEnabled="true"
                app:counterMaxLength="500">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputDescription"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:gravity="top|start"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLength="500" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutItemPrice"
                style="@style/Widget.HkuMarket.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_compact"
                android:hint="@string/item_price_hint"
                app:prefixText="HK$ ">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="numberDecimal"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutCategory"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_compact"
                android:hint="@string/item_category_hint">

                <AutoCompleteTextView
                    android:id="@+id/dropdownCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/footerPostEdit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_padding"
        android:paddingTop="@dimen/space_compact"
        android:paddingEnd="@dimen/page_padding"
        android:paddingBottom="@dimen/space_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSaveItem"
            style="@style/Widget.HkuMarket.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/post_item_action" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
