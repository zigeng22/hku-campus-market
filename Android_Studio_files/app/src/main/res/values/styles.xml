<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearance.HkuMarket.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/component_corner_radius</item>
    </style>

    <style name="ShapeAppearance.HkuMarket.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/component_corner_radius</item>
    </style>

    <style name="ShapeAppearanceOverlay.HkuMarket.ItemImage" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/component_corner_radius</item>
    </style>

    <style name="Widget.HkuMarket.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="cornerRadius">@dimen/component_corner_radius</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textAppearance">?attr/textAppearanceLabelLarge</item>
    </style>

    <style name="Widget.HkuMarket.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/component_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/component_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/component_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/component_corner_radius</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <style name="Widget.HkuMarket.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/brand_primary</item>
        <item name="titleTextColor">@color/on_primary</item>
        <item name="subtitleTextColor">@color/on_primary</item>
        <item name="navigationIconTint">@color/on_primary</item>
    </style>

    <style name="Widget.HkuMarket.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/component_corner_radius</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.HkuMarket.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="tint">@color/on_primary</item>
    </style>

    <style name="TextAppearance.HkuMarket.Brand" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/brand_brick</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HkuMarket.AuthTitle" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HkuMarket.AuthSubtitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.HkuMarket.ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HkuMarket.SectionTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HkuMarket.ItemTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HkuMarket.ItemPrice" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HkuMarket.Category" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/on_sky_container</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.HkuMarket.Metadata" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.HkuMarket.EmptyState" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.HkuMarket.Eyebrow" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/brand_brick</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.HkuMarket.DetailTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>
</resources>
